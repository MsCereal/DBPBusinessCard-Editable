@{
    ViewData["Title"] = "DBP Digital Card";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>DBP Digital Business Card</title>
    <style>
        /* ── Reset ── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(160deg, #0f172a 0%, #1e3a5f 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 30px 16px 50px;
            -webkit-tap-highlight-color: transparent;
        }

        /* ── Flip container ── */
        .flip-scene {
            width: 320px;
            height: 480px;
            perspective: 1000px;
            cursor: pointer;
        }

        .flip-card {
            width: 100%;
            height: 100%;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 0.7s cubic-bezier(0.4, 0.2, 0.2, 1);
        }

        .flip-scene.flipped .flip-card {
            transform: rotateY(180deg);
        }

        /* ── Shared face styles ── */
        .face {
            position: absolute;
            width: 100%;
            height: 100%;
            border-radius: 22px;
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
            overflow: hidden;
        }

        /* ══════════════════════════════
           FRONT — DBP Logo splash
        ══════════════════════════════ */
        .front {
            background: #ffffff;
            border-top: 6px solid #2563eb;
            border-bottom: 6px solid #dc2626;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0;
        }

        .front .dbp-logo {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2563eb, #dc2626);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 24px rgba(37,99,235,0.4);
            animation: pulse 2.4s ease-in-out infinite;
            margin-bottom: 22px;
        }

        .front .dbp-logo span {
            color: white;
            font-size: 28px;
            font-weight: bold;
            letter-spacing: -1px;
        }

        .front h2 {
            color: #111827;
            font-size: 20px;
            text-align: center;
            padding: 0 20px;
            margin-bottom: 8px;
        }

        .front .sub {
            color: #6b7280;
            font-size: 13px;
            text-align: center;
            padding: 0 24px;
            line-height: 1.5;
            margin-bottom: 32px;
        }

        .tap-hint {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }

        .tap-hint .tap-icon {
            font-size: 26px;
            animation: tap-bounce 1.6s ease-in-out infinite;
        }

        .tap-hint span:last-child {
            font-size: 12px;
            color: #9ca3af;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        /* ══════════════════════════════
           BACK — Contact card
        ══════════════════════════════ */
        .back {
            background: #ffffff;
            border-top: 6px solid #dc2626;
            border-bottom: 6px solid #2563eb;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
            transform: rotateY(180deg);
            display: flex;
            flex-direction: column;
            align-items: stretch;
            overflow-y: auto;
            padding: 24px 20px 28px;
        }

        .back-header {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 16px;
        }

        .back-logo {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2563eb, #dc2626);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .back-logo span {
            color: white;
            font-size: 14px;
            font-weight: bold;
        }

        .back-info h1 {
            font-size: 18px;
            color: #111827;
            margin-bottom: 2px;
        }

        .back-info p {
            font-size: 12px;
            color: #6b7280;
            line-height: 1.4;
        }

        .divider {
            height: 1px;
            background: #e5e7eb;
            margin: 14px 0;
            border-radius: 1px;
        }

        /* ── Buttons ── */
        .btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 14px;
            margin-bottom: 8px;
            border-radius: 11px;
            text-decoration: none;
            color: #ffffff;
            font-size: 14px;
            font-weight: bold;
            transition: transform 0.15s, opacity 0.15s;
        }

        .btn:last-child { margin-bottom: 0; }

        .btn:active { transform: scale(0.97); opacity: 0.88; }

        .btn .icon { font-size: 17px; line-height: 1; }
        .btn .lbl  { flex: 1; }

        .call     { background: #dc2626; }
        .email    { background: #2563eb; }
        .save     { background: #16a34a; }
        .github   { background: #111827; }
        .linkedin { background: #1d4ed8; }
        .site     { background: #ef4444; }

        /* flip-back button */
        .flip-back-btn {
            background: none;
            border: none;
            color: #9ca3af;
            font-size: 12px;
            cursor: pointer;
            padding: 0;
            margin-bottom: 14px;
            align-self: flex-start;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* ── Animations ── */
        @@keyframes pulse {
            0%, 100% { box-shadow: 0 8px 24px rgba(37,99,235,0.4); transform: scale(1); }
            50%       { box-shadow: 0 12px 32px rgba(37,99,235,0.6); transform: scale(1.06); }
        }

        @@keyframes tap-bounce {
            0%, 100% { transform: translateY(0); }
            50%       { transform: translateY(5px); }
        }

        /* ── Hint label below the card ── */
        .scene-hint {
            margin-top: 20px;
            color: #64748b;
            font-size: 13px;
            text-align: center;
        }

        /* ── Mobile size tweaks ── */
        @@media (max-width: 360px) {
            .flip-scene { width: 290px; height: 460px; }
        }
    </style>
</head>
<body>

<div class="flip-scene" id="flipScene" onclick="flipCard()" role="button" aria-label="Flip card to see contact details">
    <div class="flip-card" id="flipCard">

        <!-- ── FRONT ── -->
        <div class="face front">
            <div class="dbp-logo"><span>DBP</span></div>
            <h2>DBP Digital Business Card</h2>
            <p class="sub">Development Bank of the Philippines</p>
            <div class="tap-hint">
                <span class="tap-icon">👆</span>
                <span>Tap to reveal</span>
            </div>
        </div>

        <!-- ── BACK ── -->
        <div class="face back">

            <button class="flip-back-btn" onclick="flipBack(event)" aria-label="Flip back">
                ← Flip back
            </button>

            <div class="back-header">
                <div class="back-logo"><span>DBP</span></div>
                <div class="back-info">
                    <h1>Chelsea</h1>
                    <p>Software Engineer &amp; Cybersecurity Analyst<br/>Development Bank of the Philippines</p>
                </div>
            </div>

            <div class="divider"></div>

            <a class="btn call"     href="tel:+639614475634"><span class="icon">📞</span><span class="lbl">Call</span></a>
            <a class="btn email"    href="mailto:cdepurificacion@dbp.ph"><span class="icon">✉️</span><span class="lbl">Email</span></a>
            <a class="btn save"     href="/Home/DownloadContact"><span class="icon">💾</span><span class="lbl">Save to Contacts</span></a>

            <div class="divider"></div>

            <a class="btn github"   href="https://github.com/MsCereal" target="_blank" rel="noopener"><span class="icon">🐙</span><span class="lbl">GitHub</span></a>
            <a class="btn linkedin" href="https://www.linkedin.com/in/chelsea-denise-purificacion" target="_blank" rel="noopener"><span class="icon">💼</span><span class="lbl">LinkedIn</span></a>
            <a class="btn site"     href="https://www.majestyk.com" target="_blank" rel="noopener"><span class="icon">🌐</span><span class="lbl">Portfolio</span></a>

        </div>
    </div>
</div>

<p class="scene-hint" id="sceneHint">Tap the card to flip it open</p>

<script>
    var flipped = false;

    function flipCard() {
        flipped = !flipped;
        document.getElementById('flipScene').classList.toggle('flipped', flipped);
        document.getElementById('sceneHint').textContent = flipped
            ? 'Tap "← Flip back" or tap the card again'
            : 'Tap the card to flip it open';
    }

    function flipBack(e) {
        e.stopPropagation(); // don't also trigger flipCard
        flipped = false;
        document.getElementById('flipScene').classList.remove('flipped');
        document.getElementById('sceneHint').textContent = 'Tap the card to flip it open';
    }
</script>

</body>
</html>
