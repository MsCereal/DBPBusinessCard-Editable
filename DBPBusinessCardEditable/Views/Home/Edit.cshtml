@model DBPBusinessCardEditable.Models.CardProfile
@{
    ViewData["Title"] = "Edit My Card";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Edit My Card – DBP</title>
    <link rel="icon" type="image/png" href="/dbp-icon.png" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            background: #f3f4f6;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 30px 16px 50px;
        }

        .edit-wrapper {
            width: 100%;
            max-width: 420px;
            margin: 0 auto;
        }

        .edit-card {
            background: #ffffff;
            border-radius: 20px;
            padding: 30px 24px 28px;
            border-top: 6px solid #2563eb;
            border-bottom: 6px solid #dc2626;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .logo-wrap {
            text-align: center;
            margin-bottom: 16px;
        }

        .logo-img {
            width: 72px;
            height: 72px;
            object-fit: contain;
            border-radius: 50%;
        }

        h1 {
            text-align: center;
            color: #111827;
            font-size: 20px;
            margin-bottom: 6px;
        }

        .subtitle {
            text-align: center;
            color: #6b7280;
            font-size: 13px;
            margin-bottom: 20px;
        }

        .divider {
            height: 1px;
            background: #e5e7eb;
            margin: 18px 0;
        }

        .form-group {
            margin-bottom: 14px;
        }

        label {
            display: block;
            color: #374151;
            font-size: 12px;
            font-weight: bold;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        input[type="text"],
        input[type="email"],
        input[type="tel"],
        input[type="url"] {
            width: 100%;
            padding: 11px 14px;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            font-size: 14px;
            color: #111827;
            background: #f9fafb;
            outline: none;
            transition: border-color 0.15s;
        }

        input:focus {
            border-color: #2563eb;
            background: #fff;
        }

        .btn-row {
            display: flex;
            gap: 10px;
            margin-top: 8px;
        }

        .btn {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 13px 16px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            border: none;
            text-decoration: none;
            transition: transform 0.15s, opacity 0.15s;
            color: #fff;
        }

        .btn:active { transform: scale(0.97); opacity: 0.9; }

        .btn-save  { background: #2563eb; }
        .btn-reset { background: #dc2626; }
        .btn-view  { background: #16a34a; color: #fff; text-align: center; display: block; }

        .alert {
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 13px;
            margin-bottom: 16px;
            text-align: center;
            font-weight: bold;
        }

        .alert-success { background: #dcfce7; color: #15803d; }
        .alert-info    { background: #dbeafe; color: #1d4ed8; }
    </style>
</head>
<body>
<div class="edit-wrapper">
    <div class="edit-card">

        <div class="logo-wrap">
            <img src="/dbp-logo.png" alt="DBP Logo" class="logo-img" />
        </div>

        <h1>Edit My Card</h1>
        <p class="subtitle">Fill in your details — your QR will link directly to this card.</p>

        <div class="divider"></div>

        @if (TempData["Saved"] != null)
        {
            <div class="alert alert-success">✅ Card saved successfully!</div>
        }
        @if (TempData["Reset"] != null)
        {
            <div class="alert alert-info">🔄 Card has been reset.</div>
        }

        <form method="post" action="/edit">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="Name" value="@Model.Name" placeholder="e.g. Chelsea De Purificacion" maxlength="80" />
            </div>

            <div class="form-group">
                <label>Job Title</label>
                <input type="text" name="Title" value="@Model.Title" placeholder="e.g. Software Engineer" maxlength="100" />
            </div>

            <div class="form-group">
                <label>Organisation</label>
                <input type="text" name="Org" value="@Model.Org" placeholder="e.g. Development Bank of the Philippines" maxlength="120" />
            </div>

            <div class="divider"></div>

            <div class="form-group">
                <label>Phone Number</label>
                <input type="tel" name="Phone" value="@Model.Phone" placeholder="e.g. +639614475634" maxlength="30" />
            </div>

            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="Email" value="@Model.Email" placeholder="e.g. you@dbp.ph" maxlength="120" />
            </div>

            <div class="divider"></div>

            <div class="form-group">
                <label>GitHub URL</label>
                <input type="url" name="GitHub" value="@Model.GitHub" placeholder="https://github.com/username" maxlength="200" />
            </div>

            <div class="form-group">
                <label>LinkedIn URL</label>
                <input type="url" name="LinkedIn" value="@Model.LinkedIn" placeholder="https://linkedin.com/in/username" maxlength="200" />
            </div>

            <div class="form-group">
                <label>Portfolio / Website</label>
                <input type="url" name="Portfolio" value="@Model.Portfolio" placeholder="https://yoursite.com" maxlength="200" />
            </div>

            <div class="divider"></div>

            <div class="btn-row">
                <button type="submit" class="btn btn-save">💾 Save</button>
            </div>
        </form>

        <form method="post" action="/reset" style="margin-top: 10px;">
            @Html.AntiForgeryToken()
            <div class="btn-row">
                <button type="submit" class="btn btn-reset"
                        onclick="return confirm('Reset all fields? This cannot be undone.')">
                    🔄 Reset
                </button>
            </div>
        </form>

        <div class="divider"></div>

        <a href="/" class="btn btn-view">👁️ Preview My Card</a>

    </div>
</div>
</body>
</html>
