@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Card Not Found – DBP</title>
    <link rel="icon" type="image/png" href="/dbp-icon.png" />
    <link rel="stylesheet" href="~/css/card.css" />
</head>
<body>
<div class="card-wrapper">
    <div class="card">
        <div class="logo-wrap">
            <img src="/dbp-logo.png" alt="DBP Logo" class="logo-img" />
        </div>
        <h1 style="color:#dc2626;">Card Not Found</h1>
        <p class="org" style="margin-top:10px;">No card exists for this Employee ID.</p>
        <div class="divider"></div>
        <a class="btn save" href="/">Create Your Card</a>
    </div>
</div>
</body>
</html>
