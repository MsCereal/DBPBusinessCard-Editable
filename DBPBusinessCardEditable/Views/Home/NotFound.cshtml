@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Card Not Found – DBP</title>
    <link rel="icon" type="image/png" href="/dbp-icon.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: Arial, sans-serif; min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            padding: 30px 16px; position: relative; overflow: hidden;
        }
        .bg {
            position: fixed; inset: 0; z-index: 0;
            background:
                linear-gradient(155deg,
                    rgba(10,25,70,0.95) 0%, rgba(30,64,175,0.90) 45%, rgba(15,40,100,0.97) 100%),
                url('/bg.png') center/cover no-repeat;
        }
        .card {
            position: relative; z-index: 1;
            background: #fff; border-radius: 20px; padding: 36px 28px;
            text-align: center; max-width: 360px; width: 100%;
            border-top: 5px solid #2563eb; border-bottom: 4px solid #dc2626;
            box-shadow: 0 16px 48px rgba(0,0,0,0.35);
        }
        .logo-img { width: 64px; height: 64px; object-fit: contain; margin-bottom: 16px; }
        h1 { font-size: 22px; font-weight: 800; color: #dc2626; margin-bottom: 8px; }
        .sub { color: #6b7280; font-size: 14px; margin-bottom: 24px; }
        .divider { height: 1px; background: #e5e7eb; margin: 20px 0; }
        .btn {
            display: flex; align-items: center; justify-content: center;
            gap: 8px; padding: 13px 20px; border-radius: 11px;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: #fff; font-size: 15px; font-weight: 800;
            text-decoration: none; box-shadow: 0 4px 14px rgba(37,99,235,0.35);
            transition: box-shadow 0.15s;
        }
        .btn:hover { box-shadow: 0 6px 20px rgba(37,99,235,0.45); }
    </style>
</head>
<body>
<div class="bg"></div>
<div class="card">
    <img src="/dbp-logo.png" alt="DBP Logo" class="logo-img" />
    <h1>Card Not Found</h1>
    <p class="sub">No card exists for this Employee ID.</p>
    <div class="divider"></div>
    <a class="btn" href="/"><i class="fa-solid fa-plus"></i> Create Your Card</a>
</div>
</body>
</html>
