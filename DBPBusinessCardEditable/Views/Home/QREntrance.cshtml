@model DBPBusinessCardEditable.Models.CardProfile
@{
    Layout = null;
    string empId   = Model.EmpId;
    string cardUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/card/{empId}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DBP – @Model.Name</title>
    <link rel="icon" type="image/png" href="/dbp-icon.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 20px 50px;
            overflow-y: auto;
            overflow-x: hidden;
            position: relative;
        }

        /* Unified background */
        .bg {
            position: fixed; inset: 0; z-index: 0;
            background:
                linear-gradient(155deg,
                    rgba(10,25,70,0.93) 0%,
                    rgba(30,64,175,0.88) 45%,
                    rgba(15,40,100,0.96) 100%),
                url('/bg.png') center/cover no-repeat;
        }

        .wrap {
            position: relative; z-index: 1;
            width: 100%; max-width: 360px;
            text-align: center;
        }

        /* Brand header */
        .brand {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 20px;
        }
        .brand img { height: 44px; object-fit: contain; }
        .brand-text { color: #f1f5f9; font-size: 16px; font-weight: 700; letter-spacing: 0.3px; }

        /* Employee profile */
        .profile {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-bottom: 22px;
            gap: 10px;
        }
        .profile-photo {
            width: 72px; height: 72px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid rgba(255,255,255,0.25);
            background: rgba(255,255,255,0.1);
        }
        .profile-photo-placeholder {
            width: 72px; height: 72px;
            border-radius: 50%;
            background: rgba(37,99,235,0.3);
            border: 3px solid rgba(255,255,255,0.2);
            display: flex; align-items: center; justify-content: center;
        }
        .profile-photo-placeholder i { font-size: 28px; color: rgba(255,255,255,0.5); }
        .profile-name {
            color: #f1f5f9; font-size: 17px; font-weight: 700; line-height: 1.2;
        }
        .profile-title {
            color: rgba(255,255,255,0.55); font-size: 12px; margin-top: 2px;
        }
        .profile-empid {
            color: rgba(255,255,255,0.3); font-size: 11px; letter-spacing: 1px; margin-top: 1px;
        }

        /* QR frame */
        .qr-frame {
            background: #fff;
            border-radius: 18px;
            padding: 16px;
            display: inline-block;
            box-shadow: 0 0 0 1px rgba(255,255,255,0.12),
                        0 20px 50px rgba(0,0,0,0.45);
            margin-bottom: 20px;
            animation: pulse 3s ease-in-out infinite;
        }
        @@keyframes pulse {
            0%,100% { box-shadow: 0 0 0 1px rgba(255,255,255,0.12), 0 20px 50px rgba(0,0,0,0.45); }
            50%     { box-shadow: 0 0 0 6px rgba(37,99,235,0.25), 0 24px 60px rgba(0,0,0,0.5); }
        }
        .qr-frame img { display: block; width: 220px; height: 220px; border-radius: 6px; }

        /* Scan label */
        .scan-label {
            color: rgba(255,255,255,0.5); font-size: 11px;
            letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px;
        }

        /* OR divider */
        .or-row {
            display: flex; align-items: center; gap: 10px;
            margin: 0 auto 14px; max-width: 300px;
        }
        .or-row::before,.or-row::after {
            content:''; flex:1; height:1px; background:rgba(255,255,255,0.1);
        }
        .or-row span { color: rgba(255,255,255,0.3); font-size: 10px; letter-spacing: 2px; }

        /* Copy link row */
        .copy-row {
            display: flex; gap: 8px; align-items: stretch;
            max-width: 340px; margin: 0 auto 24px;
        }
        .copy-box {
            flex: 1; min-width: 0;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 10px;
            padding: 10px 12px;
            color: #93c5fd; font-size: 11px;
            word-break: break-all; text-align: left;
        }

        /* Unified buttons */
        .btn {
            display: flex; align-items: center; justify-content: center;
            gap: 8px; padding: 12px 16px;
            border-radius: 11px; font-size: 14px; font-weight: 700;
            cursor: pointer; border: none; text-decoration: none;
            transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
            white-space: nowrap; flex-shrink: 0;
        }
        .btn:active { transform: scale(0.97); }
        .btn i { font-size: 14px; }

        /* Primary blue — solid */
        .btn-primary {
            background: #2563eb; color: #fff;
            box-shadow: 0 4px 14px rgba(37,99,235,0.35);
        }
        .btn-primary:hover { background: #1d4ed8; box-shadow: 0 6px 18px rgba(37,99,235,0.45); }

        /* Outline white — for secondary actions */
        .btn-outline {
            background: rgba(255,255,255,0.08);
            border: 1.5px solid rgba(255,255,255,0.2);
            color: #f1f5f9;
        }
        .btn-outline:hover { background: rgba(255,255,255,0.15); }

        /* Danger outline — reset only, subtle */
        .btn-danger {
            background: transparent;
            border: 1.5px solid rgba(255,255,255,0.15);
            color: rgba(255,255,255,0.45);
            font-size: 13px;
        }
        .btn-danger:hover { border-color: rgba(239,68,68,0.5); color: #fca5a5; }

        /* Action row */
        .action-row {
            display: flex; gap: 10px;
            max-width: 340px; margin: 0 auto;
        }
        .action-row > * { flex: 1; }
        .action-row form { display: flex; }
        .action-row form button { width: 100%; }
    </style>
</head>
<body>

<div class="bg"></div>

<div class="wrap">

    <!-- Brand -->
    <div class="brand">
        <img src="/dbp-logo.png" alt="DBP" />
        <span class="brand-text">Digital Business Card</span>
    </div>

    <!-- Employee profile -->
    <div class="profile">
        @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
        {
            <img src="@Model.PhotoUrl" alt="@Model.Name" class="profile-photo"
                 onerror="this.style.display='none';document.getElementById('phPlaceholder').style.display='flex';" />
            <div class="profile-photo-placeholder" id="phPlaceholder" style="display:none;">
                <i class="fa-solid fa-user"></i>
            </div>
        }
        else
        {
            <div class="profile-photo-placeholder">
                <i class="fa-solid fa-user"></i>
            </div>
        }
        <div>
            <p class="profile-name">@Model.Name</p>
            @if (!string.IsNullOrWhiteSpace(Model.Title))
            {
                <p class="profile-title">@Model.Title</p>
            }
            <p class="profile-empid">@Model.EmpId</p>
        </div>
    </div>

    <!-- QR Code -->
    <div class="qr-frame">
        <img src="/QR/Generate/@empId" alt="QR Code for @Model.Name" />
    </div>

    <p class="scan-label">Scan to view card</p>

    <div class="or-row"><span>OR COPY LINK</span></div>

    <div class="copy-row">
        <div class="copy-box" id="linkBox">@cardUrl</div>
        <button class="btn btn-primary" id="copyBtn" onclick="copyLink()">
            <i class="fa-solid fa-copy"></i> Copy
        </button>
    </div>

    <!-- Owner actions -->
    <div class="action-row">
        <a href="/setup?empId=@empId" class="btn btn-outline">
            <i class="fa-solid fa-pen-to-square"></i> Edit Card
        </a>
        <form method="post" action="/reset/@empId">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger"
                    onclick="return confirm('Reset all card info? This cannot be undone.')">
                <i class="fa-solid fa-rotate-left"></i> Reset
            </button>
        </form>
    </div>

</div>

<script>
    var cardUrl = '@cardUrl';
    function copyLink() {
        navigator.clipboard.writeText(cardUrl).then(function() {
            var btn = document.getElementById('copyBtn');
            btn.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
            btn.style.background = '#16a34a';
            setTimeout(function() {
                btn.innerHTML = '<i class="fa-solid fa-copy"></i> Copy';
                btn.style.background = '';
            }, 2000);
        }).catch(function() {
            var el = document.createElement('textarea');
            el.value = cardUrl;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
        });
    }
</script>

</body>
</html>
