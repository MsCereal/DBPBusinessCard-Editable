@model DBPBusinessCardEditable.Models.CardProfile
@{
    Layout = null;
    string empId   = Model.EmpId;
    string cardUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/card/{empId}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DBP – @Model.Name</title>
    <link rel="icon" type="image/png" href="/dbp-icon.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            min-height: 100vh;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            padding: 36px 20px 50px;
            overflow-y: auto; overflow-x: hidden;
            position: relative;
        }

        .bg {
            position: fixed; inset: 0; z-index: 0;
            background:
                linear-gradient(155deg,
                    rgba(10,25,70,0.93) 0%,
                    rgba(30,64,175,0.88) 45%,
                    rgba(15,40,100,0.96) 100%),
                url('/bg.png') center/cover no-repeat;
        }

        .wrap {
            position: relative; z-index: 1;
            width: 100%; max-width: 400px;
            text-align: center;
        }

        /* ── Brand ── */
        .brand {
            display: flex; align-items: center; justify-content: center;
            gap: 12px; margin-bottom: 24px;
        }
        .brand img { height: 42px; object-fit: contain; }
        .brand-text { color: #f1f5f9; font-size: 15px; font-weight: 700; letter-spacing: 0.3px; }

        /* ── Profile ── */
        .profile { margin-bottom: 24px; }

        .profile-photo-wrap {
            margin-bottom: 12px;
        }
        .profile-photo, .profile-photo-placeholder {
            width: 80px; height: 80px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid rgba(255,255,255,0.35);
            box-shadow: 0 4px 16px rgba(0,0,0,0.3);
            display: block; margin: 0 auto;
        }
        .profile-photo-placeholder {
            background: rgba(37,99,235,0.4);
            display: flex; align-items: center; justify-content: center;
            overflow: hidden;
        }
        .profile-photo-placeholder i { font-size: 32px; color: rgba(255,255,255,0.6); }
        .profile-photo-placeholder img { width: 100%; height: 100%; object-fit: cover; display: block; }

        .profile-name {
            color: #ffffff;
            font-size: 20px; font-weight: 800;
            letter-spacing: 0.3px;
            margin-bottom: 6px;
            text-shadow: 0 1px 6px rgba(0,0,0,0.4);
        }

        /* Title pill — readable against dark bg */
        .profile-title-pill {
            display: inline-block;
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.2);
            color: #f1f5f9;
            font-size: 12px; font-weight: 600;
            padding: 4px 12px; border-radius: 20px;
            margin-bottom: 5px;
            backdrop-filter: blur(4px);
        }

        .profile-empid {
            color: rgba(255,255,255,0.5);
            font-size: 11px; letter-spacing: 1.5px;
            font-weight: 600;
        }

        /* ── QR Card ── */
        .qr-card {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.14);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 16px;
            backdrop-filter: blur(8px);
        }

        .qr-frame {
            background: #fff;
            border-radius: 14px;
            padding: 14px;
            display: inline-block;
            box-shadow: 0 8px 30px rgba(0,0,0,0.4);
            margin-bottom: 14px;
            animation: pulse 3s ease-in-out infinite;
        }
        @@keyframes pulse {
            0%,100% { box-shadow: 0 8px 30px rgba(0,0,0,0.4); }
            50%     { box-shadow: 0 8px 30px rgba(0,0,0,0.4), 0 0 0 6px rgba(37,99,235,0.2); }
        }
        .qr-frame img { display: block; width: 200px; height: 200px; border-radius: 4px; }

        .qr-instruction {
            color: rgba(255,255,255,0.9);
            font-size: 13px; font-weight: 700;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }
        .qr-sub {
            color: rgba(255,255,255,0.45);
            font-size: 11px;
        }

        /* ── Action buttons ── */
        .link-section {
            margin-bottom: 20px;
        }

        .divider-row {
            display: flex; align-items: center; gap: 10px;
            margin: 0 auto 14px; max-width: 340px;
        }
        .divider-row::before, .divider-row::after {
            content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.12);
        }
        .divider-row span { color: rgba(255,255,255,0.35); font-size: 10px; letter-spacing: 2px; white-space: nowrap; }

        /* Two side-by-side buttons: Open Card + Copy Link */
        .access-row {
            display: flex; gap: 10px; margin-bottom: 0;
        }

        .btn {
            display: flex; align-items: center; justify-content: center;
            gap: 8px; padding: 13px 16px;
            border-radius: 12px; font-size: 14px; font-weight: 700;
            cursor: pointer; border: none; text-decoration: none;
            transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
            flex: 1;
        }
        .btn:active { transform: scale(0.97); }
        .btn i { font-size: 14px; }

        /* "Open Card" — solid blue — primary action for laptop/web */
        .btn-open {
            background: #2563eb; color: #fff;
            box-shadow: 0 4px 14px rgba(37,99,235,0.4);
        }
        .btn-open:hover { background: #1d4ed8; }

        /* "Copy Link" — glass outline */
        .btn-copy {
            background: rgba(255,255,255,0.1);
            border: 1.5px solid rgba(255,255,255,0.2);
            color: #f1f5f9;
        }
        .btn-copy:hover { background: rgba(255,255,255,0.18); }

        /* ── Owner actions ── */
        .owner-row {
            display: flex; gap: 10px;
        }
        .btn-edit {
            background: rgba(255,255,255,0.08);
            border: 1.5px solid rgba(255,255,255,0.2);
            color: #f1f5f9; flex: 1;
        }
        .btn-edit:hover { background: rgba(255,255,255,0.15); }

        .btn-reset {
            background: transparent;
            border: 1.5px solid rgba(255,255,255,0.12);
            color: rgba(255,255,255,0.4);
            font-size: 13px; flex: 1;
        }
        .btn-reset:hover { border-color: rgba(239,68,68,0.5); color: #fca5a5; }

        /* Save QR button */
        .btn-save-qr {
            display: flex; align-items: center; justify-content: center;
            gap: 8px; padding: 11px 16px;
            border-radius: 11px; font-size: 13px; font-weight: 700;
            cursor: pointer; border: 1.5px solid rgba(255,255,255,0.2);
            background: rgba(255,255,255,0.08); color: #f1f5f9;
            transition: background 0.15s, transform 0.1s;
        }
        .btn-save-qr:hover { background: rgba(255,255,255,0.16); }
        .btn-save-qr:active { transform: scale(0.97); }
        .btn-save-qr i { font-size: 14px; }
    </style>
</head>
<body>

<div class="bg"></div>

<div class="wrap">

    <!-- Brand -->
    <div class="brand">
        <img src="/dbp-logo.png" alt="DBP" />
        <span class="brand-text">Digital Business Card</span>
    </div>

    <!-- Employee Profile -->
    <div class="profile">
        <div class="profile-photo-wrap">
            @if (!string.IsNullOrWhiteSpace(Model.Photo) && Model.Photo.StartsWith("data:"))
            {
                <img src="@Model.Photo" alt="@Model.Name" class="profile-photo" />
            }
            else if (Model.Photo == "avatar:male")
            {
                <div class="profile-photo-placeholder">
                    <img src="/dbp-boy.png" alt="Male" style="width:100%;height:100%;object-fit:cover;" />
                </div>
            }
            else if (Model.Photo == "avatar:female")
            {
                <div class="profile-photo-placeholder">
                    <img src="/dbp-girl.png" alt="Female" style="width:100%;height:100%;object-fit:cover;" />
                </div>
            }
            else
            {
                <div class="profile-photo-placeholder">
                    <i class="fa-solid fa-user"></i>
                </div>
            }
        </div>

        <p class="profile-name">@Model.Name</p>
        @if (!string.IsNullOrWhiteSpace(Model.Title))
        {
            <p class="profile-title-pill">@Model.Title</p>
        }
        <p class="profile-empid">@Model.EmpId</p>
    </div>

    <!-- QR Code card -->
    <div class="qr-card">
        <div class="qr-frame" id="qrFrameWrap">
            <img src="/QR/Generate/@empId" alt="QR Code" id="qrImg" crossorigin="anonymous" />
        </div>
        <p class="qr-instruction"><i class="fa-solid fa-camera" style="margin-right:6px;opacity:0.7;"></i>Scan with your phone camera</p>
        <p class="qr-sub">to view @Model.Name's digital business card</p>

        <!-- Save QR button — right under the QR -->
        <button class="btn btn-save-qr" id="saveQrBtn" onclick="saveQr()" style="margin-top:14px;width:100%;">
            <i class="fa-solid fa-download"></i> Save QR Code
        </button>
    </div>

    <!-- Access section: Open Card + Copy Link -->
    <div class="link-section">
        <div class="divider-row"><span>OR ACCESS DIRECTLY</span></div>
        <div class="access-row">
            <a href="@cardUrl" class="btn btn-open" target="_blank" rel="noopener">
                <i class="fa-solid fa-id-card"></i> Open Card
            </a>
            <button class="btn btn-copy" id="copyBtn" onclick="copyLink()">
                <i class="fa-solid fa-copy"></i> Copy Link
            </button>
        </div>
    </div>

    <!-- Owner actions -->
    <div class="owner-row">
        <a href="/setup?empId=@empId" class="btn btn-edit">
            <i class="fa-solid fa-pen-to-square"></i> Edit Card
        </a>
        <form method="post" action="/reset/@empId" style="flex:1;display:flex;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-reset" style="width:100%;"
                    onclick="return confirm('Reset all card info? This cannot be undone.')">
                <i class="fa-solid fa-rotate-left"></i> Reset
            </button>
        </form>
    </div>

</div>

<script>
    var cardUrl = '@cardUrl';
    var empId   = '@empId';
    var empName = '@Model.Name';

    function copyLink() {
        navigator.clipboard.writeText(cardUrl).then(function() {
            var btn = document.getElementById('copyBtn');
            btn.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
            btn.style.background = 'rgba(22,163,74,0.6)';
            btn.style.borderColor = 'rgba(22,163,74,0.5)';
            setTimeout(function() {
                btn.innerHTML = '<i class="fa-solid fa-copy"></i> Copy Link';
                btn.style.background = '';
                btn.style.borderColor = '';
            }, 2000);
        }).catch(function() {
            var el = document.createElement('textarea');
            el.value = cardUrl;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
        });
    }

    function saveQr() {
        var btn = document.getElementById('saveQrBtn');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';
        btn.disabled = true;

        // Fetch the QR image and convert to downloadable blob
        fetch('/QR/Generate/' + empId)
            .then(function(r) { return r.blob(); })
            .then(function(blob) {
                var url = URL.createObjectURL(blob);
                var a = document.createElement('a');
                a.href = url;
                a.download = empName.replace(/\s+/g, '-') + '-QR.png';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);

                btn.innerHTML = '<i class="fa-solid fa-check"></i> QR Saved!';
                btn.style.background = 'rgba(22,163,74,0.4)';
                btn.style.borderColor = 'rgba(22,163,74,0.5)';
                setTimeout(function() {
                    btn.innerHTML = '<i class="fa-solid fa-download"></i> Save QR Code';
                    btn.style.background = '';
                    btn.style.borderColor = '';
                    btn.disabled = false;
                }, 2500);
            })
            .catch(function() {
                // Fallback: open QR image directly for manual save
                window.open('/QR/Generate/' + empId, '_blank');
                btn.innerHTML = '<i class="fa-solid fa-download"></i> Save QR Code';
                btn.disabled = false;
            });
    }
</script>

</body>
</html>
