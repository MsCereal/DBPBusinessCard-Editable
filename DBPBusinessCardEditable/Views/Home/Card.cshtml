@model DBPBusinessCardEditable.Models.CardProfile
@{
    Layout = null;
    string cardUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/card/{Model.EmpId}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Name – DBP Digital Card</title>
    <link rel="icon" type="image/png" href="/dbp-icon.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 30px 16px 60px;
            position: relative;
            overflow-y: auto; overflow-x: hidden;
        }

        /* Unified blue bg */
        .page-bg {
            position: fixed; inset: 0; z-index: 0;
            background:
                linear-gradient(155deg,
                    rgba(10,25,70,0.95) 0%,
                    rgba(30,64,175,0.90) 45%,
                    rgba(15,40,100,0.97) 100%),
                url('/bg.png') center/cover no-repeat;
        }

        /* Flip hint */
        .flip-hint {
            position: relative; z-index: 1;
            color: rgba(255,255,255,0.35);
            font-size: 11px; letter-spacing: 1px;
            margin-bottom: 12px; cursor: pointer;
            user-select: none; text-align: center;
        }
        .flip-hint i { margin-right: 4px; }

        /* Card scene */
        .card-scene {
            position: relative; z-index: 1;
            width: 100%; max-width: 380px;
            perspective: 1000px;
        }
        .card-flipper {
            width: 100%; position: relative;
            transform-style: preserve-3d;
            transition: transform 0.55s cubic-bezier(0.4,0.2,0.2,1);
        }
        .card-flipper.flipped { transform: rotateY(180deg); }

        /* Card faces */
        .card-face {
            width: 100%;
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 16px 48px rgba(0,0,0,0.35);
            overflow: hidden;
        }

        /* Blue accent bar — moved to BOTTOM, away from photo */
        .card-face::before {
            content: '';
            display: block;
            height: 5px;
            background: linear-gradient(90deg, #1e3a8a, #2563eb, #60a5fa);
            position: absolute;
            bottom: 0; left: 0; right: 0;
            border-radius: 0 0 20px 20px;
        }

        .card-front { padding: 28px 20px 32px; text-align: center; position: relative; }
        .card-back  {
            position: absolute; top: 0; left: 0;
            padding: 22px 20px 32px;
            transform: rotateY(180deg);
            text-align: left;
        }

        /* ── FRONT ── */
        .logo-img { width: 64px; height: 64px; object-fit: contain; margin-bottom: 14px; display: block; margin-left: auto; margin-right: auto; }

        /* Profile photo with DBP badge */
        .profile-header {
            text-align: center;
            margin-bottom: 14px;
        }
        .profile-photo-wrap {
            position: relative;
            display: inline-block;
        }
        .profile-photo {
            width: 90px; height: 90px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #e5e7eb;
            box-shadow: 0 4px 16px rgba(0,0,0,0.12);
            display: block;
        }
        .profile-avatar {
            width: 90px; height: 90px;
            border-radius: 50%;
            background: #eff6ff;
            border: 3px solid #bfdbfe;
            display: flex; align-items: center; justify-content: center;
            overflow: hidden;
        }
        .profile-avatar img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 50%; }
        .profile-avatar i { font-size: 38px; color: #93c5fd; }

        /* Small DBP logo badge overlapping bottom-right */
        .dbp-badge {
            position: absolute;
            bottom: 2px; right: -4px;
            width: 30px; height: 30px;
            border-radius: 50%;
            background: #fff;
            border: 2px solid #e5e7eb;
            box-shadow: 0 2px 6px rgba(0,0,0,0.15);
            display: flex; align-items: center; justify-content: center;
            overflow: hidden;
        }
        .dbp-badge img { width: 26px; height: 26px; object-fit: contain; }

        .logo-img { width: 56px; height: 56px; object-fit: contain; margin-bottom: 14px; display: block; margin-left: auto; margin-right: auto; }

        h1 { color: #0f172a; font-size: 21px; font-weight: 800; margin-bottom: 4px; }
        .job-title { color: #334155; font-size: 13px; font-weight: 500; margin-bottom: 3px; }
        .org-name  { color: #64748b; font-size: 12px; }

        .divider { height: 1px; background: #f1f5f9; margin: 14px 0; }

        /* Buttons — blue outline, fill on hover */
        .btn {
            display: flex; align-items: center; justify-content: center;
            gap: 9px; padding: 11px 14px; margin: 6px 0;
            border-radius: 10px; text-decoration: none;
            font-size: 13px; font-weight: 700;
            background: #fff;
            border: 1.5px solid #2563eb;
            color: #2563eb;
            transition: background 0.16s, color 0.16s, box-shadow 0.16s, transform 0.1s;
            cursor: pointer; width: 100%;
        }
        .btn i { font-size: 14px; width: 16px; text-align: center; flex-shrink: 0; }
        .btn:hover { background: #2563eb; color: #fff; box-shadow: 0 4px 16px rgba(37,99,235,0.3); }
        .btn:active { transform: scale(0.97); background: #1d4ed8; color: #fff; }

        /* Share gets slightly different shade to distinguish */
        .btn-share { border-color: #1e3a8a; color: #1e3a8a; }
        .btn-share:hover { background: #1e3a8a; color: #fff; box-shadow: 0 4px 16px rgba(30,58,138,0.3); }

        /* ── BACK ── */
        .back-header {
            display: flex; align-items: center; gap: 10px;
            margin-bottom: 16px; padding-bottom: 14px;
            border-bottom: 1px solid #f1f5f9;
        }
        .back-logo { width: 32px; height: 32px; object-fit: contain; }
        .back-header-text strong { display: block; color: #0f172a; font-size: 14px; font-weight: 800; }
        .back-header-text span   { color: #94a3b8; font-size: 11px; }
        .back-close {
            margin-left: auto; background: none; border: none;
            color: #94a3b8; font-size: 17px; cursor: pointer; padding: 4px; line-height: 1;
        }
        .back-close:hover { color: #334155; }

        .info-hint {
            font-size: 11px; color: #94a3b8;
            margin-bottom: 12px; display: flex; align-items: center; gap: 5px;
        }

        .info-row {
            display: flex; align-items: flex-start; gap: 10px;
            padding: 9px 10px; border-radius: 9px; margin-bottom: 5px;
            cursor: pointer;
            border: 1px solid #f1f5f9;
            transition: background 0.14s, border-color 0.14s;
        }
        .info-row:hover { background: #f0f7ff; border-color: #bfdbfe; }
        .info-row:active { background: #dbeafe; }

        .info-icon {
            width: 30px; height: 30px; border-radius: 7px;
            background: #eff6ff;
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .info-icon i { font-size: 12px; color: #2563eb; }

        .info-content { flex: 1; min-width: 0; }
        .info-label  { font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 1px; }
        .info-value  { font-size: 13px; color: #0f172a; font-weight: 500; word-break: break-all; }

        .copy-tick { font-size: 12px; color: #16a34a; opacity: 0; transition: opacity 0.2s; flex-shrink: 0; align-self: center; }
        .copy-tick.show { opacity: 1; }

        .back-actions { margin-top: 14px; padding-top: 12px; border-top: 1px solid #f1f5f9; }

        @@media (max-width: 480px) {
            body { padding: 20px 12px 50px; }
            h1 { font-size: 19px; }
        }
    </style>
</head>
<body>

<div class="page-bg"></div>

<div class="flip-hint" onclick="flipCard()" id="flipHint">
    <i class="fa-solid fa-rotate"></i> Tap card to flip &amp; view details
</div>

<div class="card-scene" id="cardScene">
<div class="card-flipper" id="cardFlipper">

    <!-- ── FRONT ── -->
    <div class="card-face card-front" id="cardFront" onclick="flipCard()">

        <!-- Profile header: photo with DBP logo badge -->
        <div class="profile-header">
            <div class="profile-photo-wrap">
                @if (!string.IsNullOrWhiteSpace(Model.Photo) && Model.Photo.StartsWith("data:"))
                {
                    <img src="@Model.Photo" alt="@Model.Name" class="profile-photo" />
                }
                else if (Model.Photo == "avatar:male")
                {
                    <div class="profile-photo profile-avatar">
                        <img src="/dbp-boy.png" alt="Male" style="width:100%;height:100%;object-fit:cover;" />
                    </div>
                }
                else if (Model.Photo == "avatar:female")
                {
                    <div class="profile-photo profile-avatar">
                        <img src="/dbp-girl.png" alt="Female" style="width:100%;height:100%;object-fit:cover;" />
                    </div>
                }
                else
                {
                    <div class="profile-photo profile-avatar"><i class="fa-solid fa-user"></i></div>
                }
                <!-- DBP logo badge bottom-right of photo -->
                <div class="dbp-badge">
                    <img src="/dbp-logo.png" alt="DBP" />
                </div>
            </div>
        </div>

        <h1>@Model.Name</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Title)) { <p class="job-title">@Model.Title</p> }
        @if (!string.IsNullOrWhiteSpace(Model.Org))   { <p class="org-name">@Model.Org</p> }

        <div class="divider"></div>

        @if (!string.IsNullOrWhiteSpace(Model.Phone))
        {
            <a class="btn" href="tel:@Model.Phone" onclick="event.stopPropagation()">
                <i class="fa-solid fa-phone"></i> Call Now
            </a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Email))
        {
            <a class="btn" href="mailto:@Model.Email" onclick="event.stopPropagation()">
                <i class="fa-solid fa-envelope"></i> Send Email
            </a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Phone) || !string.IsNullOrWhiteSpace(Model.Email))
        {
            <a class="btn" href="/download-contact/@Model.EmpId" onclick="event.stopPropagation()">
                <i class="fa-solid fa-address-card"></i> Save Contact
            </a>
        }

        @if (!string.IsNullOrWhiteSpace(Model.GitHub) || !string.IsNullOrWhiteSpace(Model.LinkedIn) || !string.IsNullOrWhiteSpace(Model.Portfolio))
        { <div class="divider"></div> }

        @if (!string.IsNullOrWhiteSpace(Model.GitHub))
        {
            <a class="btn" href="@Model.GitHub" target="_blank" rel="noopener" onclick="event.stopPropagation()">
                <i class="fa-brands fa-github"></i> View GitHub
            </a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.LinkedIn))
        {
            <a class="btn" href="@Model.LinkedIn" target="_blank" rel="noopener" onclick="event.stopPropagation()">
                <i class="fa-brands fa-linkedin"></i> View LinkedIn
            </a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Portfolio))
        {
            <a class="btn" href="@Model.Portfolio" target="_blank" rel="noopener" onclick="event.stopPropagation()">
                <i class="fa-solid fa-globe"></i> Visit Website
            </a>
        }

        <div class="divider"></div>
        <button class="btn btn-share" onclick="shareCard(); event.stopPropagation();" id="shareBtn">
            <i class="fa-solid fa-share-nodes"></i> Share This Card
        </button>

    </div><!-- /front -->

    <!-- ── BACK ── -->
    <div class="card-face card-back" id="cardBack">

        <div class="back-header">
            <img src="/dbp-logo.png" alt="DBP" class="back-logo" />
            <div class="back-header-text">
                <strong>@Model.Name</strong>
                <span>Tap any row to copy</span>
            </div>
            <button class="back-close" onclick="flipCard()">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <p class="info-hint"><i class="fa-solid fa-circle-info"></i> Tap a row to copy to clipboard</p>

        @if (!string.IsNullOrWhiteSpace(Model.Name))
        {
            <div class="info-row" onclick="copyInfo(this,'@Model.Name')">
                <div class="info-icon"><i class="fa-solid fa-user"></i></div>
                <div class="info-content"><p class="info-label">Full Name</p><p class="info-value">@Model.Name</p></div>
                <i class="fa-solid fa-check copy-tick"></i>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Title))
        {
            <div class="info-row" onclick="copyInfo(this,'@Model.Title')">
                <div class="info-icon"><i class="fa-solid fa-briefcase"></i></div>
                <div class="info-content"><p class="info-label">Job Title</p><p class="info-value">@Model.Title</p></div>
                <i class="fa-solid fa-check copy-tick"></i>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Org))
        {
            <div class="info-row" onclick="copyInfo(this,'@Model.Org')">
                <div class="info-icon"><i class="fa-solid fa-building-columns"></i></div>
                <div class="info-content"><p class="info-label">Organization</p><p class="info-value">@Model.Org</p></div>
                <i class="fa-solid fa-check copy-tick"></i>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Phone))
        {
            <div class="info-row" onclick="copyInfo(this,'@Model.Phone')">
                <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
                <div class="info-content"><p class="info-label">Phone</p><p class="info-value">@Model.Phone</p></div>
                <i class="fa-solid fa-check copy-tick"></i>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Email))
        {
            <div class="info-row" onclick="copyInfo(this,'@Model.Email')">
                <div class="info-icon"><i class="fa-solid fa-envelope"></i></div>
                <div class="info-content"><p class="info-label">Email</p><p class="info-value">@Model.Email</p></div>
                <i class="fa-solid fa-check copy-tick"></i>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.GitHub))
        {
            <div class="info-row" onclick="copyInfo(this,'@Model.GitHub')">
                <div class="info-icon"><i class="fa-brands fa-github"></i></div>
                <div class="info-content"><p class="info-label">GitHub</p><p class="info-value">@Model.GitHub</p></div>
                <i class="fa-solid fa-check copy-tick"></i>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.LinkedIn))
        {
            <div class="info-row" onclick="copyInfo(this,'@Model.LinkedIn')">
                <div class="info-icon"><i class="fa-brands fa-linkedin"></i></div>
                <div class="info-content"><p class="info-label">LinkedIn</p><p class="info-value">@Model.LinkedIn</p></div>
                <i class="fa-solid fa-check copy-tick"></i>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Portfolio))
        {
            <div class="info-row" onclick="copyInfo(this,'@Model.Portfolio')">
                <div class="info-icon"><i class="fa-solid fa-globe"></i></div>
                <div class="info-content"><p class="info-label">Website</p><p class="info-value">@Model.Portfolio</p></div>
                <i class="fa-solid fa-check copy-tick"></i>
            </div>
        }

        <div class="back-actions">
            <button class="btn btn-share" onclick="shareCard()">
                <i class="fa-solid fa-share-nodes"></i> Share This Card
            </button>
        </div>

    </div><!-- /back -->

</div>
</div>

<script>
    var cardUrl  = '@Html.Raw(cardUrl)';
    var cardName = '@Html.Raw(Model.Name)';

    function syncHeight() {
        var front   = document.getElementById('cardFront');
        var back    = document.getElementById('cardBack');
        var flipper = document.getElementById('cardFlipper');
        var scene   = document.getElementById('cardScene');
        var flipped = flipper.classList.contains('flipped');
        var h = flipped ? back.scrollHeight : front.offsetHeight;
        flipper.style.height = h + 'px';
        scene.style.height   = h + 'px';
        // Also update back absolute height to its own content
        back.style.height = back.scrollHeight + 'px';
    }
    window.addEventListener('load', syncHeight);
    window.addEventListener('resize', syncHeight);

    function flipCard() {
        var flipper = document.getElementById('cardFlipper');
        var hint    = document.getElementById('flipHint');
        var flipped = flipper.classList.toggle('flipped');
        hint.innerHTML = flipped
            ? '<i class="fa-solid fa-rotate-left"></i> Tap ✕ or card to flip back'
            : '<i class="fa-solid fa-rotate"></i> Tap card to flip &amp; view details';
        setTimeout(syncHeight, 300); // after flip animation
    }

    function copyInfo(row, text) {
        var tick = row.querySelector('.copy-tick');
        navigator.clipboard.writeText(text).then(function() {
            tick.classList.add('show');
            row.style.background = '#f0fdf4';
            row.style.borderColor = '#86efac';
            setTimeout(function() {
                tick.classList.remove('show');
                row.style.background = '';
                row.style.borderColor = '';
            }, 2000);
        }).catch(function() {
            var el = document.createElement('textarea');
            el.value = text; document.body.appendChild(el);
            el.select(); document.execCommand('copy');
            document.body.removeChild(el);
            tick.classList.add('show');
            setTimeout(function() { tick.classList.remove('show'); }, 2000);
        });
    }

    function shareCard() {
        if (navigator.share) {
            navigator.share({
                title: cardName + ' – DBP Digital Business Card',
                text: 'View ' + cardName + '\'s digital business card',
                url: cardUrl
            }).catch(function() {});
        } else {
            navigator.clipboard.writeText(cardUrl).then(function() {
                var btn = document.getElementById('shareBtn');
                btn.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
                setTimeout(function() {
                    btn.innerHTML = '<i class="fa-solid fa-share-nodes"></i> Share This Card';
                }, 2500);
            }).catch(function() { prompt('Copy this link:', cardUrl); });
        }
    }
</script>

</body>
</html>
