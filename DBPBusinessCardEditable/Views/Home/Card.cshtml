@model DBPBusinessCardEditable.Models.CardProfile
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@Model.Name – DBP Digital Card</title>
    <link rel="icon" type="image/png" href="/dbp-icon.png" />
    <link rel="stylesheet" href="~/css/card.css" />
</head>
<body>

<div class="card-wrapper">
    <div class="card">

        <div class="logo-wrap">
            <img src="/dbp-logo.png" alt="DBP Logo" class="logo-img" />
        </div>

        <h1>@Model.Name</h1>

        @if (!string.IsNullOrWhiteSpace(Model.Title))
        {
            <p class="title">@Model.Title</p>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Org))
        {
            <p class="org">@Model.Org</p>
        }

        <div class="divider"></div>

        @if (!string.IsNullOrWhiteSpace(Model.Phone))
        {
            <a class="btn call" href="tel:@Model.Phone">
                <span class="icon">📞</span> Call
            </a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Email))
        {
            <a class="btn email" href="mailto:@Model.Email">
                <span class="icon">✉️</span> Email
            </a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Phone) || !string.IsNullOrWhiteSpace(Model.Email))
        {
            <a class="btn save" href="/download-contact/@Model.EmpId">
                <span class="icon">💾</span> Save to Contacts
            </a>
        }

        @if (!string.IsNullOrWhiteSpace(Model.GitHub) || !string.IsNullOrWhiteSpace(Model.LinkedIn) || !string.IsNullOrWhiteSpace(Model.Portfolio))
        {
            <div class="divider"></div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.GitHub))
        {
            <a class="btn github" href="@Model.GitHub" target="_blank" rel="noopener">
                <span class="icon">🐙</span> GitHub
            </a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.LinkedIn))
        {
            <a class="btn linkedin" href="@Model.LinkedIn" target="_blank" rel="noopener">
                <span class="icon">💼</span> LinkedIn
            </a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Portfolio))
        {
            <a class="btn site" href="@Model.Portfolio" target="_blank" rel="noopener">
                <span class="icon">🌐</span> Portfolio
            </a>
        }

    </div>
</div>

</body>
</html>
